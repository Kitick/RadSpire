root = true

[*]
indent_size = 4
indent_style = tab
tab_width = 4

end_of_line = lf
insert_final_newline = true

[*.cs]
csharp_space_after_cast = true
csharp_new_line_before_open_brace = none
csharp_style_prefer_primary_constructors = false
csharp_space_after_keywords_in_control_flow_statements = false
csharp_style_implicit_object_creation_when_type_is_apparent = false

# Explicit types over var
csharp_style_var_for_built_in_types = false:warning
csharp_style_var_when_type_is_apparent = false:warning
csharp_style_var_elsewhere = false:warning

# Expression-bodied members
csharp_style_expression_bodied_properties = true:warning
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_accessors = when_on_single_line:suggestion

# Explicit access modifiers
dotnet_style_require_accessibility_modifiers = always:warning

# Null simplification
dotnet_diagnostic.IDE0029.severity = warning
dotnet_diagnostic.IDE0030.severity = warning
dotnet_diagnostic.IDE0031.severity = warning

# Modifier order
csharp_preferred_modifier_order = public,private,protected,internal,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,volatile,async:warning

# Readonly fields
dotnet_style_readonly_field = true:warning

# Prefer collection expressions
csharp_style_prefer_collection_expression = true:warning
dotnet_diagnostic.IDE0300.severity = warning
dotnet_diagnostic.IDE0301.severity = warning
dotnet_diagnostic.IDE0302.severity = warning
dotnet_diagnostic.IDE0303.severity = warning
dotnet_diagnostic.IDE0304.severity = warning
dotnet_diagnostic.IDE0305.severity = warning

# PascalCase for all fields (private and public)
dotnet_naming_symbols.all_fields.applicable_kinds = field
dotnet_naming_symbols.all_fields.applicable_accessibilities = *

dotnet_naming_style.pascal_case_style.capitalization = pascal_case

dotnet_naming_rule.fields_must_be_pascal_case.symbols = all_fields
dotnet_naming_rule.fields_must_be_pascal_case.style = pascal_case_style
dotnet_naming_rule.fields_must_be_pascal_case.severity = warning
